{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mbn-theme/image-box",
  "title": "Image Box",
  "category": "mbn-blocks",
  "icon": "format-image",
  "description": "A flexible box with image, title, content and button",
  "keywords": ["image", "box", "card", "content"],
  "textdomain": "mbn-theme",
  "editorScript": "file:./index.js",
  "style": "file:./style.css",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "gradients": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number"
    },
    "imagePosition": {
      "type": "string",
      "default": "left",
      "enum": ["left", "right", "top", "background"]
    },
    "imageWidth": {
      "type": "string",
      "default": "50%"
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "titleTag": {
      "type": "string",
      "default": "h2",
      "enum": ["h2", "h3", "h4", "h5", "span"]
    },
    "titleClass": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": "#"
    },
    "buttonStyle": {
      "type": "string",
      "default": "primary",
      "enum": ["primary", "secondary", "outline"]
    },
    "buttonTarget": {
      "type": "boolean",
      "default": false
    },
    "titleColor": {
      "type": "string",
      "default": ""
    },
    "titleFontSize": {
      "type": "number",
      "default": 0
    },
    "contentColor": {
      "type": "string",
      "default": ""
    },
    "contentFontSize": {
      "type": "number",
      "default": 0
    },
    "listContent": {
      "type": "string",
      "default": ""
    },
    "listType": {
      "type": "string",
      "default": "ul",
      "enum": ["ul", "ol"]
    },
    "listFontSize": {
      "type": "number",
      "default": 0
    },
    "listColor": {
      "type": "string",
      "default": ""
    },
    "showList": {
      "type": "boolean",
      "default": true
    }
  }
}
