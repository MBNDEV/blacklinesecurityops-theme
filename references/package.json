{
  "name": "mbn-landers",
  "version": "1.0.0",
  "description": "Gutenberg-based landing page builder",
  "private": true,
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i assets/css/src/app.css -o assets/css/app.min.css --minify",
    "build:block-css": "node scripts/build-block-css.js",
    "build:blocks": "wp-scripts build",
    "build": "npm run build:css && npm run build:blocks && npm run build:block-css",
    "build:block": "BLOCK=$npm_config_block wp-scripts build && node scripts/build-block-css.js $npm_config_block",
    "build:template": "BLOCK=$npm_config_template wp-scripts build && node scripts/build-block-css.js $npm_config_template",
    "start:css": "npx @tailwindcss/cli -i assets/css/src/app.css -o assets/css/app.min.css --watch",
    "start:blocks": "wp-scripts start",
    "lint:js": "wp-scripts lint-js",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@wordpress/block-editor": "^14.0.0",
    "@wordpress/blocks": "^13.0.0",
    "@wordpress/components": "^28.0.0",
    "@wordpress/core-data": "^7.0.0",
    "@wordpress/data": "^10.0.0",
    "@wordpress/edit-post": "^8.0.0",
    "@wordpress/editor": "^14.0.0",
    "@wordpress/element": "^6.0.0",
    "@wordpress/i18n": "^5.0.0",
    "@wordpress/icons": "^10.0.0",
    "@wordpress/plugins": "^7.0.0",
    "@wordpress/scripts": "^28.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
